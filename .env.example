# Copy this file to ".env" and fill in the values. NEVER commit ".env".
# On Vercel, set these in Project → Settings → Environment Variables instead.

# Postgres connection string (e.g. Neon — use the POOLED string for serverless).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Founding pre-order page (/founding) ---
# Your PayPal payment link (or other hosted checkout link):
FOUNDING_DEPOSIT_URL=""
# PayPal hosted-button SDK. This client-id is PUBLIC (ships in browser code) — safe.
PAYPAL_HOSTED_CLIENT_ID=""
PAYPAL_HOSTED_BUTTON_ID=""
# Optional Loom/YouTube embed URL for the demo video:
FOUNDING_DEMO_URL=""
# Optional public repo link (open-source trust signal):
FOUNDING_REPO_URL=""

# --- Automation (later) — THESE ARE SECRETS. Keep out of git; set in Vercel env. ---
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"   # or "live"
